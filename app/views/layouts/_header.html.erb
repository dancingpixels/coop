<% if Current.user %>
<div class="min-h-screen bg-gradient-to-br from-slate-100 via-white to-slate-200">

  <!-- Mobile Menu Toggle -->
  <input
    id="nav-toggle"
    type="checkbox"
    class="peer hidden">

  <!-- Overlay -->
  <label
    for="nav-toggle"
    class="fixed inset-0 z-40 hidden bg-black/60 backdrop-blur-sm peer-checked:block lg:hidden">
  </label>

  <!-- Off Canvas Navigation -->

 
  <aside class="fixed inset-y-0 left-0 z-50 flex w-72 -translate-x-full flex-col bg-black text-white shadow-2xl transition-transform duration-300 peer-checked:translate-x-0 lg:hidden">

    <div class="flex items-center justify-between border-b border-slate-800 px-6 py-5">

      <div>
        <h2 class="text-xl font-bold">
          Dashboard
        </h2>
        <p class="text-sm text-slate-400">
          Welcome back
        </p>
      </div>

      <label
        for="nav-toggle"
        class="cursor-pointer rounded-lg p-2 transition hover:bg-slate-800">

        <svg class="h-6 w-6"
             fill="none"
             stroke="currentColor"
             viewBox="0 0 24 24">
          <path stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"/>
        </svg>

      </label>

    </div>


    <nav class="flex-1 space-y-2 p-4">

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        🏠 <span class="ml-3">Dashboard</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        👤 <span class="ml-3">Profile</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        ⚙️ <span class="ml-3">Settings</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        📊 <span class="ml-3">Reports</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        📁 <span class="ml-3">Projects</span>
      <% end %>

      <%= button_to "Sign Out", session_path, method: :delete, class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" %>

    </nav>

    <div class="border-t border-slate-800 p-6">

      <p class="text-sm text-slate-400">
        Signed in as
      </p>

      <p class="mt-1 font-semibold">
        <%= Current.user.name %>
      </p>

    </div>

  </aside>



  <!-- Header -->
  <header class="sticky top-0 z-30 bg-black text-white shadow-xl">

    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">

      <div class="flex items-center gap-4">

        <!-- Mobile Menu Button -->
        <label
          for="nav-toggle"
          class="cursor-pointer rounded-lg p-2 transition hover:bg-slate-800 lg:hidden">

          <svg class="h-6 w-6"
               fill="none"
               stroke="currentColor"
               viewBox="0 0 24 24">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"/>
          </svg>

        </label>

        <div>

          <h1 class="text-xl font-bold">
            Welcome 👋
          </h1>

          <p class="text-xs text-slate-400">
            <%= Date.current.strftime("%A, %B %d, %Y") %>
          </p>

        </div>

      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden items-center gap-8 text-sm font-medium lg:flex">


        
        <%= link_to "Dashboard", users_path , class: "hover:text-indigo-400 transition" %>
        <%= link_to "Profile", user_path(Current.user) , class: "hover:text-indigo-400 transition" %>
        <%= button_to "Sign out", session_path, 
              method: :delete, class: "hover:text-indigo-400 transition" %>

      </nav>


    </div>

  </header>

<% end %>