<div class="min-h-screen flex items-center justify-center bg-gray-50 px-6">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">
        Create a new password
      </h1>

      <p class="mt-2 text-gray-600">
        Choose a strong password that you haven't used before.
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl p-8">

      <% if alert = flash[:alert] %>
        <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4 text-red-700">
          <%= alert %>
        </div>
      <% end %>

      <% if notice = flash[:notice] %>
        <div class="mb-6 rounded-lg border border-green-200 bg-green-50 p-4 text-green-700">
          <%= notice %>
        </div>
      <% end %>

      <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-6" do |form| %>

       
        <div>
          <%= form.label :password,
              "New Password",
              class: "block text-sm font-medium text-gray-700 mb-2" %>

          <div class="relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-gray-400">
              🔒
            </span>

            <%= form.password_field :password,
                required: true,
                autocomplete: "new-password",
                maxlength: 72,
                placeholder: "Enter your new password",
                class: "w-full rounded-lg border border-gray-300 pl-10 pr-4 py-3 shadow-sm transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500" %>
          </div>

          <p class="mt-2 text-xs text-gray-500">
            Use at least 8 characters with a mix of letters, numbers, and symbols.
          </p>
        </div>

      
        <div>
          <%= form.label :password_confirmation,
              "Confirm Password",
              class: "block text-sm font-medium text-gray-700 mb-2" %>

          <div class="relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-gray-400">
              🔒
            </span>

            <%= form.password_field :password_confirmation,
                required: true,
                autocomplete: "new-password",
                maxlength: 72,
                placeholder: "Confirm your new password",
                class: "w-full rounded-lg border border-gray-300 pl-10 pr-4 py-3 shadow-sm transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500" %>
          </div>
        </div>

     
        <%= form.submit "Update Password",
            class: "w-full rounded-lg bg-blue-600 py-3 text-white font-semibold shadow hover:bg-blue-700 transition duration-200 cursor-pointer" %>

      <% end %>

    </div>

    <p class="mt-6 text-center text-sm text-gray-500">
      Remember your password?
      <%= link_to "Sign in",
          new_session_path,
          class: "font-medium text-blue-600 hover:text-blue-700" %>
    </p>

  </div>
</div>