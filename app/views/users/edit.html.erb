<div class="max-w-md mx-auto my-10 p-6 bg-white border border-gray-200 rounded-xl shadow-sm">
  <h1 class="text-2xl font-bold text-gray-900">Edit Profile</h1>
  <p class="mt-1 text-sm text-gray-500">Update your email address and phone number.</p>

  <% if @user.errors.any? %>
    <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600">
      <h2 class="font-semibold mb-2"><%= pluralize(@user.errors.count, "error") %> prevented this profile from being saved:</h2>
      <ul class="list-disc pl-5 space-y-1">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with(model: @user, class: "mt-6 space-y-5") do |f| %>
    <div>
      <%= f.label :email_address, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email_address, class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm shadow-sm transition" %>
    </div>

    <div>
      <%= f.label :telephone, class: "block text-sm font-medium text-gray-700 mb-1" %> 
      <%= f.telephone_field :telephone, placeholder: '00000000000', class: "w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm shadow-sm transition" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Update Profile", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer transition" %>
    </div>
  <% end %>

  <div class="mt-6 text-center border-t border-gray-100 pt-4">
    <%= link_to "Back to profile", user_path(@user), class: "text-sm text-gray-600 hover:text-gray-900 font-medium transition" %>
  </div>
</div>