
    <!-- Hero -->
    <section class="rounded-3xl bg-gradient-to-r from-indigo-700 via-violet-700 to-fuchsia-700 p-8 text-white shadow-xl">

      <p class="text-lg text-indigo-100">
        AVAILABLE BALANCE
      </p>

      <h2 class="mt-2 text-5xl font-extrabold">
      <%= number_to_currency(@savings_balance, 
          unit: "₦", delimiter: ",", precision: 2) %>
      </h2>

      <p class="mt-5 max-w-2xl leading-relaxed text-indigo-100">
        All transactions up to date. Let's get cracking.
      </p>

    </section>

    <!-- Cards -->
    <section class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">

      <div class="rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200">

        <h3 class="mb-6 text-xl font-bold">
          Profile
        </h3>

        <dl class="space-y-5">

          <div>
            <dt class="text-sm text-slate-500">Name</dt>
            <dd class="font-semibold"><%= Current.user.name %></dd>
          </div>

          <div>
            <dt class="text-sm text-slate-500">Email</dt>
            <dd class="break-all"><%= Current.user.email_address %></dd>
          </div>

          <div>
            <dt class="text-sm text-slate-500">Status</dt>
            <dd>
              <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-sm font-semibold text-emerald-700">
                <%= Current.user.status.titleize %>
              </span>
            </dd>
          </div>

        </dl>

      </div>

 

  <div class="rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200">

  <h3 class="mb-6 text-xl font-bold">
    Transaction Snapshot
  </h3>

  <div class="space-y-4 text-slate-700">

    <div class="flex justify-between">
      <span>Date</span>
      <strong><%= @transaction_date.strftime("%B %d, %Y") %></strong>
    </div>

    <div class="flex justify-between">
      <span>Savings Balance</span>
      <strong class="text-emerald-600">
        <%= number_to_currency(@savings_balance, 
            unit: "₦", delimiter: ",", precision: 2) %>
      </strong>
    </div>

    <div class="flex justify-between">
      <span>Savings Debit</span>
      <strong class="text-red-600">
        <%= number_to_currency(@savings_debit, 
            unit: "₦", delimiter: ",", precision: 2) %>
      </strong>
    </div>

    <div class="flex justify-between">
      <span>Loan Balance</span>
      <strong class="text-emerald-600">
        <%= number_to_currency(@loan_balance, 
            unit: "₦", delimiter: ",", precision: 2) %>
      </strong>
    </div>

    <div class="flex justify-between">
      <span>Loan repayment</span>
      <strong class="text-emerald-600">
        <%= number_to_currency(@loan_repayment, 
        unit: "₦", delimiter: ",", precision: 2) %>
      </strong>
    </div>

  </div>

</div>

<div class="rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200">

        <h3 class="mb-6 text-xl font-bold">
          Quick Actions
        </h3>

        <div class="space-y-3">

          <%= link_to "View Profile", user_path(Current.user),
              class: "block rounded-xl bg-black px-5 py-3 text-center font-semibold text-white hover:bg-slate-800 transition" %>

          <%= link_to "Transaction History", transactions_path,
              class: "block rounded-xl border border-slate-300 px-5 py-3 text-center hover:bg-slate-100 transition" %>

          <%= link_to "Loan Applications", "#",
              class: "block rounded-xl border border-slate-300 px-5 py-3 text-center hover:bg-slate-100 transition" %>

        </div>

      </div>

    </section>

</div>