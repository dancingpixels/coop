<div class="min-h-screen bg-gradient-to-br from-slate-100 via-white to-slate-200">

  <!-- Mobile Menu Toggle -->
  <input
    id="nav-toggle"
    type="checkbox"
    class="peer hidden">

  <!-- Overlay -->
  <label
    for="nav-toggle"
    class="fixed inset-0 z-40 hidden bg-black/60 backdrop-blur-sm peer-checked:block lg:hidden">
  </label>

  <!-- Off Canvas Navigation -->
  <aside class="fixed inset-y-0 left-0 z-50 flex w-72 -translate-x-full flex-col bg-black text-white shadow-2xl transition-transform duration-300 peer-checked:translate-x-0 lg:hidden">

    <div class="flex items-center justify-between border-b border-slate-800 px-6 py-5">

      <div>
        <h2 class="text-xl font-bold">
          Dashboard
        </h2>
        <p class="text-sm text-slate-400">
          Welcome back
        </p>
      </div>

      <label
        for="nav-toggle"
        class="cursor-pointer rounded-lg p-2 transition hover:bg-slate-800">

        <svg class="h-6 w-6"
             fill="none"
             stroke="currentColor"
             viewBox="0 0 24 24">
          <path stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"/>
        </svg>

      </label>

    </div>

    <nav class="flex-1 space-y-2 p-4">

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        🏠 <span class="ml-3">Dashboard</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        👤 <span class="ml-3">Profile</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        ⚙️ <span class="ml-3">Settings</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        📊 <span class="ml-3">Reports</span>
      <% end %>

      <%= link_to "#", class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" do %>
        📁 <span class="ml-3">Projects</span>
      <% end %>

      <%= button_to "Sign Out", session_path, method: :delete, class: "flex items-center rounded-xl px-4 py-3 hover:bg-slate-900 transition" %>

    </nav>

    <div class="border-t border-slate-800 p-6">

      <p class="text-sm text-slate-400">
        Signed in as
      </p>

      <p class="mt-1 font-semibold">
        <%= Current.user.name %>
      </p>

    </div>

  </aside>

  <!-- Header -->
  <header class="sticky top-0 z-30 bg-black text-white shadow-xl">

    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">

      <div class="flex items-center gap-4">

        <!-- Mobile Menu Button -->
        <label
          for="nav-toggle"
          class="cursor-pointer rounded-lg p-2 transition hover:bg-slate-800 lg:hidden">

          <svg class="h-6 w-6"
               fill="none"
               stroke="currentColor"
               viewBox="0 0 24 24">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"/>
          </svg>

        </label>

        <div>

          <h1 class="text-xl font-bold">
            Welcome 👋
          </h1>

          <p class="text-xs text-slate-400">
            <%= Date.current.strftime("%A, %B %d, %Y") %>
          </p>

        </div>

      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden items-center gap-8 text-sm font-medium lg:flex">


        
        <%= link_to "Dashboard", "#", class: "hover:text-indigo-400 transition" %>
        <%= link_to "Profile", "#", class: "hover:text-indigo-400 transition" %>
        <%= button_to "Sign out", session_path, 
              method: :delete, class: "hover:text-indigo-400 transition" %>

      </nav>

    </div>

  </header>

  <!-- Main -->
  <main class="mx-auto max-w-7xl px-6 py-10">

    <!-- Hero -->
    <section class="rounded-3xl bg-gradient-to-r from-indigo-700 via-violet-700 to-fuchsia-700 p-8 text-white shadow-xl">

      <p class="text-lg text-indigo-100">
        Good to see you again,
      </p>

      <h2 class="mt-2 text-5xl font-extrabold">
        <%= Current.user.name %>
      </h2>

      <p class="mt-5 max-w-2xl leading-relaxed text-indigo-100">
        All transactions up to date. Let's get cracking.
      </p>

    </section>

    <!-- Cards -->
    <section class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">

      <div class="rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200">

        <h3 class="mb-6 text-xl font-bold">
          Profile
        </h3>

        <dl class="space-y-5">

          <div>
            <dt class="text-sm text-slate-500">Name</dt>
            <dd class="font-semibold"><%= Current.user.name %></dd>
          </div>

          <div>
            <dt class="text-sm text-slate-500">Email</dt>
            <dd class="break-all"><%= Current.user.email_address %></dd>
          </div>

          <div>
            <dt class="text-sm text-slate-500">Status</dt>
            <dd>
              <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-sm font-semibold text-emerald-700">
                <%= Current.user.status.titleize %>
              </span>
            </dd>
          </div>

        </dl>

      </div>

      <div class="rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200">

        <h3 class="mb-6 text-xl font-bold">
          Transaction Snapshot
        </h3>

        <div class="space-y-4 text-slate-700">

          <div class="flex justify-between">
            <span>Date</span>
            <strong><%= Date.current.strftime("%A, %B %d, %Y") %></strong>
          </div>

          <div class="flex justify-between">
            <span>Savings Balance</span>
            <strong></strong>
          </div>

          <div class="flex justify-between">
            <span>Savings Debit</span>
            <strong></strong>
          </div>

          <div class="flex justify-between">
            <span>Loan Balance</span>
            <strong class="text-emerald-600">
            </strong>
          </div>

          <div class="flex justify-between">
            <span>Loan Credit</span>
            <strong class="text-emerald-600">
            </strong>
          </div>

        </div>

      </div>

      <div class="rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200">

        <h3 class="mb-6 text-xl font-bold">
          Quick Actions
        </h3>

        <div class="space-y-3">

          <%= link_to "View Profile", "#",
              class: "block rounded-xl bg-black px-5 py-3 text-center font-semibold text-white hover:bg-slate-800 transition" %>

          <%= link_to "Transaction History", "#",
              class: "block rounded-xl border border-slate-300 px-5 py-3 text-center hover:bg-slate-100 transition" %>

          <%= link_to "Loan Applications", "#",
              class: "block rounded-xl border border-slate-300 px-5 py-3 text-center hover:bg-slate-100 transition" %>

        </div>

      </div>

    </section>

  </main>

  <!-- Footer -->
  <footer class="mt-16 bg-black text-slate-400">

    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm md:flex-row">

      <p>
        &copy; <%= Date.current.year %> Equity Coop Alausa, Ikeja
      </p>

      <nav class="flex flex-wrap gap-6">

        <%#= link_to "Contact Us", "#", class: "hover:text-white transition" %>

      </nav>

    </div>

  </footer>

</div>